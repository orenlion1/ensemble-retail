{
  "title": "Ensemble-Grafana Ecommerce Overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["ensemble-grafana", "ecommerce", "faro", "spring-boot"],
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (application, uri) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (application, uri) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Duration",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, application, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Service Logs",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{namespace=\"ensemble-grafana\"}"
        }
      ]
    },
    {
      "type": "traces",
      "title": "Frontend to Backend Traces",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "query": "service.name=\"ensemble-grafana-storefront\" OR service.namespace=\"ensemble-grafana\""
        }
      ]
    }
  ]
}
