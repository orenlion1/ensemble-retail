VITE_FARO_URL=https://faro-collector-prod-us-east-3.grafana.net/collect/5a68e2237d01ef9a66c697cd87090b55
VITE_FARO_API_KEY=replace-with-grafana-cloud-faro-api-key
VITE_FARO_ENVIRONMENT=production

# Public Cognito Hosted UI settings. The Google IdP is configured behind
# Cognito; never put the Google client secret in frontend env.
VITE_COGNITO_HOSTED_UI_DOMAIN=https://ensemble-grafana.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=replace-with-cognito-app-client-id
# Redirect URI is auto-derived at runtime from window.location.origin (so the same build
# works on every served domain, e.g. ensemble-grafana.com and ensemble-retail.com). Each
# origin's "/auth/callback" must be registered on the Cognito app client. No env var needed.

# Source map uploads use Grafana's build-time Rollup/Vite plugin. These are not
# VITE_ variables because they should stay in the build environment.
FARO_SOURCEMAP_ENDPOINT=replace-with-grafana-faro-sourcemap-api-url
FARO_SOURCEMAP_API_KEY=replace-with-grafana-sourcemap-api-key
FARO_APP_ID=replace-with-grafana-frontend-observability-app-id
FARO_STACK_ID=replace-with-grafana-stack-id
FARO_BUNDLE_ID=ensemble-grafana-1.0.0
FARO_KEEP_SOURCEMAPS=false
FARO_SOURCEMAP_VERBOSE=false
