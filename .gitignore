.DS_Store
.m2/
node_modules/
dist/
target/
.terraform/
terraform.tfstate
terraform.tfstate.*
*.tfstate.backup
*.tfplan
**/tfplan

# Terraform variables and generated handoff files (may contain secrets)
*.tfvars
*.tfvars.json
infra/terraform/network.auto.tfvars.json
infra/terraform/stacks/**/terraform.tfvars

# Environment and credential files
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
observability/synthetic-monitoring/.env
observability/synthetic-monitoring/probe-tokens.env
**/credentials.json
**/*-credentials.json
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# Kubernetes runtime secrets (use *.example.template.yaml / secrets.example.yaml in git)
infra/k8s/secrets.yaml
infra/k8s/observability-secrets.yaml
infra/k8s/observability-secrets.example.yaml

*.log
*.class
playwright-report/
test-results/
browser-devtools-*.png
lighthouse-devtools*/

# Raw observability pulls can include runtime tokens or high-volume API payloads.
reports/load-tests/k6-*.json
reports/frontend-user-actions/*.json

# Client-specific IRM generated batches are local/private by default.
observability/irm/generated/*-incident-push-results.json
observability/irm/generated/*-incident-push-summary.md
observability/irm/generated/*-incidents-to-push.json
observability/irm/generated/*-placeholder-manifests/
observability/irm/generated/sample-placeholder-incident-*.yaml
observability/irm/*-placeholder-incidents-review.md
